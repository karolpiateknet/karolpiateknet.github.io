---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredSlugs = [
  'Initialization-side-effects',
  'How-to-save-milions-in-software-development-1',
  'including-production-changes-for-unit-tests',
];

const featured = featuredSlugs
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter(Boolean);

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Karol Piątek" description="Staff iOS Engineer building agentic AI dev tools and automation.">
  <section class="hero">
    <p class="hero__eyebrow">Karol Piątek · Staff iOS Engineer</p>
    <h1 class="hero__title">I help engineering teams ship faster with AI.</h1>
    <p class="hero__lede">
      I'm a Staff iOS Engineer at TransferGo. My day job is making AI useful inside an engineering team - agents, custom skills, automated reviews. This site is where I write about it.
    </p>
    <a href="/about" class="hero__cta">More about me</a>
  </section>

  <section>
    <p class="section-eyebrow">Featured</p>
    <ul class="post-list">
      {featured.map((post) => (
        <li class="post-list__item">
          <h2 class="post-list__title"><a href={`/${post!.id}`}>{post!.data.title}</a></h2>
          <div class="post-list__meta">
            <time datetime={post!.data.date.toISOString()}>{fmt(post!.data.date)}</time>
          </div>
          {post!.data.description && <p class="post-list__excerpt">{post!.data.description}</p>}
        </li>
      ))}
    </ul>
  </section>

  <section>
    <p class="section-eyebrow">All writing</p>
    <ul class="post-list">
      {allPosts.map((post) => (
        <li class="post-list__item">
          <h2 class="post-list__title">
            <a href={post.data.redirectTo ?? `/${post.id}`}>{post.data.title}</a>
          </h2>
          <div class="post-list__meta">
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
            {post.data.redirectTo && <span class="tag-chip">External</span>}
            {post.data.tags.slice(0, 3).map((tag) => (
              <a href={`/tags/${tag.toLowerCase()}`} class="tag-chip">{tag}</a>
            ))}
          </div>
        </li>
      ))}
    </ul>
  </section>
</Base>
